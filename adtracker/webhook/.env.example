DATABASE_URL=postgresql://user:password@localhost:5432/adtracker
WEBHOOK_PORT=3001

# Google Ads webhook signature verification (set this in Google Ads webhook settings)
GOOGLE_ADS_WEBHOOK_SECRET=your-webhook-secret-here

# Google Ads API credentials (for attribution lookup / sync scripts)
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-client-id
GOOGLE_ADS_CLIENT_SECRET=your-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your-manager-account-id