DATABASE_URL=postgresql://user:password@localhost:5432/adtracker
PORT=3002
FRONTEND_ORIGIN=http://localhost:5173

# Basic auth for the dashboard -- this API exposes lead PII (names, emails,
# phones), so it should never be left open. Swap for real user accounts
# later if more than one person needs access with different permissions.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=choose-a-strong-password-here
